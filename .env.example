# ProjectKeystone Docker Environment
#
# Run ./scripts/setup-env.sh to auto-generate .env with correct values
# Or manually copy this file to .env and update the values:
#
#   cp .env.example .env
#   echo "BUILD_UID=$(id -u)" >> .env
#   echo "BUILD_GID=$(id -g)" >> .env

# Git commit hash for Docker image tagging
GIT_COMMIT=dev

# Host user/group IDs for Docker volume permissions
# These should match your host user to avoid permission issues
BUILD_UID=1000
BUILD_GID=1000
